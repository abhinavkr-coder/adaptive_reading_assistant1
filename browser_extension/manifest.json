{
  "manifest_version": 3,
  "name": "Adaptive Reading Assistant",
  "version": "2.1",
  "description": "AI-powered reading simplifier. Every word, at your level.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://localhost:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Adaptive Reader"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js":      ["content.js"],
      "css":     ["styles.css"],
      "run_at":  "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["library_image.avif"],
      "matches":   ["<all_urls>"]
    }
  ]
}