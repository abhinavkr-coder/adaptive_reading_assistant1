{
  "manifest_version": 3,
  "name": "Adaptive Reading Assistant",
  "version": "2.0",
  "description": "AI-powered paragraph simplification. Rewrites entire pages at your reading level.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://localhost:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Adaptive Reader"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js":      ["content.js"],
      "css":     ["styles.css"],
      "run_at":  "document_idle"
    }
  ]
}